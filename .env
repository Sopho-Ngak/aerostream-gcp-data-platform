# Kafka Configuration
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TOPIC=aviation_flights

# OpenSky API
OPENSKY_API_URL=https://opensky-network.org/api/states/all
API_TIMEOUT=10
FETCH_INTERVAL=30

# HDFS Configuration
HDFS_NAMENODE=namenode:9000
HDFS_BASE_PATH=/aviation

# GCP Configuration
GCP_PROJECT_ID=aerostream-project
GCS_BUCKET_NAME=aerostream-data-lake
GCP_REGION=us-central1
BIGQUERY_DATASET=aviation

# Spark Configuration
SPARK_MASTER=spark://spark-master:7077
SPARK_EXECUTOR_MEMORY=2g
SPARK_DRIVER_MEMORY=2g

# Airflow
AIRFLOW_HOME=/opt/airflow
